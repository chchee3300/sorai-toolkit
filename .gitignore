# Developer tools' files
.lite_workspace.lua

# Node dependencies
/node_modules

# Neutralino runtime auth/session info (contains tokens)
/.tmp

# Claude Code local (machine-specific) settings
.claude/settings.local.json

# Neutralinojs binaries and builds
/bin
/dist

# Vite build output (Phase 1 scaffold — distinct from Neutralino's own /dist)
/web-dist

# Third-party executables fetched by setup.mjs (ffmpeg, qpdf, etc.) — too large for GitHub
/binaries

# CI packaging output (packaging/*/build.sh, packaging/windows/build.ps1)
/release-assets

# Regenerated fresh by generate-context-menu-registry.mjs before every
# installer build -- never hand-edited, never stale in git.
/packaging/windows/context-menu.generated.iss

# Same convention, Linux side -- regenerated fresh by
# packaging/linux/generate-context-menu-registry.mjs before every
# .deb/.rpm build.
/packaging/linux/context-menu.generated/

# Neutralinojs client (minified)
neutralino.js

# Neutralinojs related files
.storage
*.log
